chain mosproxy_dns_redirect {
type nat hook prerouting priority dstnat; policy accept;

          # Only LAN clients. The router's own queries (incl. mosproxy's
          # udp://1.1.1.1:53 bootstrap) use the OUTPUT path, never prerouting,
          # so they are NOT caught here — no loop.
          iifname "br-lan" udp dport 53 redirect to :5553
          iifname "br-lan" tcp dport 53 redirect to :5553
      }
